{
  "expo": {
    "name": "DeepFlow",
    "slug": "deepflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "deepflow",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deepflow.app"
    },
    "android": {
      "package": "com.deepflow.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-notifications"
    ]
  }
}